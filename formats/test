import pdfplumber
import re

def debug_baml(chemin_pdf, max_pages=3):
    with pdfplumber.open(chemin_pdf) as pdf:
        for i, page in enumerate(pdf.pages[:max_pages]):
            words = page.extract_words()
            if not words:
                continue

            lignes_mots = {}
            for w in words:
                y = round(w['top'], 1)
                if y not in lignes_mots:
                    lignes_mots[y] = []
                lignes_mots[y].append(w)

            # Chercher entête LONG/SHORT
            header_y = None
            for y in sorted(lignes_mots.keys()):
                mots = lignes_mots[y]
                texte_ligne = " ".join(w['text'] for w in mots)
                if ("LONG" in texte_ligne and "SHORT" in texte_ligne
                        and "TRADE" in texte_ligne and "CONTRACT" in texte_ligne):
                    header_y = y
                    print(f"\n{'='*60}")
                    print(f"PAGE {i+1} - Header trouvé à y={y}")
                    print(f"{'='*60}")
                    break

            if not header_y:
                continue

            # Afficher les 40 premières lignes après le header
            ys_sorted = [y for y in sorted(lignes_mots.keys()) if y > header_y]
            print(f"{'Y':>8} | {'TEXTE BRUT'}")
            print("-" * 80)
            for y in ys_sorted[:40]:
                mots = lignes_mots[y]
                # Afficher chaque mot avec sa position x
                detail = "  |  ".join(f"[x={w['x0']:.0f} '{w['text']}']" for w in mots)
                texte = " ".join(w['text'] for w in mots)
                # Marquer les lignes candidates (contiennent des chiffres)
                has_digit = bool(re.search(r'\d', texte))
                marker = ">>>" if has_digit else "   "
                print(f"{marker} y={y:6.1f} | {texte}")
                # Si la ligne contient *, afficher le détail
                if '*' in texte or re.search(r'\b\d+\b', texte):
                    print(f"         DETAIL: {detail}")

# Lancer le debug
chemin = r"T:\Dallas\CSS-BOC\CTL\REC\Réconciliation dérivés listés"  # ← adapter le chemin
debug_baml(chemin)
