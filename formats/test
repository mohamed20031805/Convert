import pdfplumber, re
p = r'T:\Dallas\CSS-BOC\CTL\REC\Réconciliation dérivés listés\FUND CHANNEL\2026\BAML\MSIM_SG_EOD Daily Statement.pdf'
with pdfplumber.open(p) as pdf:
    page = pdf.pages[1]  # page 2
    words = page.extract_words()
    lignes_mots = {}
    for w in words:
        y = round(w['top'], 1)
        if y not in lignes_mots:
            lignes_mots[y] = []
        lignes_mots[y].append(w)
    
    ys = sorted(lignes_mots.keys())
    for idx, y in enumerate(ys):
        texte = ' '.join(w['text'] for w in lignes_mots[y])
        if re.search(r'\d+\*', texte):
            # Afficher 3 lignes avant
            for j in range(max(0,idx-3), idx+1):
                y2 = ys[j]
                print(f'y={y2:6} | {[(w[\"text\"], round(w[\"x0\"],1)) for w in lignes_mots[y2]]}')
            print('---')
