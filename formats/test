def matcher_produit(product_pdf, df_client):
    """
    Matcher sur NOM + MOIS + ANNÉE ensemble
    """
    product_upper = product_pdf.upper().strip()

    # Extraire Mon + Yr depuis le produit PDF
    mc = re.search(r'(JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)\s*(\d{2})', product_upper)
    mon_pdf = mc.group(1) if mc else ""
    yr_pdf  = mc.group(2) if mc else ""

    # Étape 1 : MAPPING_DIRECT + vérifier Mon + Yr
    for cle_pdf, cle_client in MAPPING_DIRECT.items():
        if cle_pdf.upper() in product_upper:
            for _, row in df_client.iterrows():
                desc = str(row["Security Description"]).upper()
                if cle_client.upper() in desc:
                    # Vérifier mois + année dans description client
                    mc2 = re.search(
                        r'(JAN|FEB|MAR|APR|MAY|JUN|JUL|AUG|SEP|OCT|NOV|DEC)\s*(\d{2})',
                        desc
                    )
                    mon_client = mc2.group(1) if mc2 else ""
                    yr_client  = mc2.group(2) if mc2 else ""

                    if mon_pdf == mon_client and yr_pdf == yr_client:
                        return row["Security Description"]

    return None
