def extraire_client_page(lignes):
    """
    Extraire le nom client depuis les lignes de la page.
    Le nom est entre l'adresse SG et ATTN/CONFIRMATIONS.
    """
    client_parts = []
    capture = False

    for ligne in lignes:
        l = ligne.strip()

        # Commencer à capturer après adresse SG
        if any(x in l for x in ["PARIS LA DEFENSE", "COURS VALMY", "92987"]):
            capture = True
            continue

        if capture:
            # Arrêter à ATTN ou CONFIRMATIONS
            if any(x in l for x in ["ATTN", "CONFIRMATION", "DISCRETIONARY"]):
                break
            # Ignorer lignes adresse client (numéros, pays, villes)
            if not l:
                continue
            if any(x in l for x in [
                "SWITZERLAND", "LUXEMBOURG", "VIA ", "69000", "L-2520",
                "L 2520", "5 ALLEE", "SCHEFFER", "LUGANO", "EMILIO"
            ]):
                continue
            # Garder lignes avec contenu
            if len(l) > 3:
                client_parts.append(l)

    return " - ".join(client_parts) if client_parts else ""
