python -c "
import pdfplumber
import re

p = r'T:\Dallas\CSS-BOC\CTL\REC\Réconciliation dérivés listés\ASB AXION\2026\01. JANVIER\20260130_DLY_STMT.pdf'
with pdfplumber.open(p) as pdf:
    for i, page in enumerate(pdf.pages[:6]):
        texte = page.extract_text() or ''
        account = ''
        client  = ''
        for ligne in texte.split('\n'):
            m = re.search(r'ACCOUNT NUMBER\s*:\s*(.+)', ligne)
            if m:
                account = m.group(1).strip()
            if any(x in ligne.upper() for x in ['FUND', 'SICAV']) and \
               not any(x in ligne for x in ['LME', 'DERIVATIVE', 'EXCHANGE']):
                if ligne.strip() and len(ligne.strip()) > 5:
                    client = ligne.strip()
        print(f'Page {i+1} | Account: {account}')
        print(f'         Client extrait: {repr(client)}')
        print()
"
