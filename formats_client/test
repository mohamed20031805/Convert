def trouver_onglet(client_pdf, onglets):
    # Tokeniser sur les mots AVANT normalisation
    STOP_WORDS = {"ASB", "AXION", "SICAV", "FUND", "SA", "BANK",
                  "SWISS", "BANCASTATO", "AZIONARIO", "AND", "THE"}

    tokens_pdf = set(
        w.upper() for w in re.findall(r'[A-Za-z]{3,}', client_pdf)
    ) - STOP_WORDS

    best_match = None
    best_score = 0

    for desc, df in onglets.items():
        tokens_desc = set(
            w.upper() for w in re.findall(r'[A-Za-z]{3,}', desc)
        ) - STOP_WORDS

        score = len(tokens_pdf & tokens_desc)
        print(f"  [{desc}] tokens_pdf={tokens_pdf} & tokens_desc={tokens_desc} = {tokens_pdf & tokens_desc} score={score}")

        if score > best_score:
            best_score = score
            best_match = desc

    print(f"✅ Match: {best_match} (score={best_score})")
    return best_match if best_score >= 1 else None
