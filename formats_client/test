def lire_desc_port(df_raw):
    """
    Chercher 'Desc. Port.' dans les 8 premières lignes
    et retourner la valeur qui suit sur la même ligne
    """
    for i in range(8):
        row = df_raw.iloc[i]
        row_list = list(row)
        for j, v in enumerate(row_list):
            if "Desc" in str(v) and "Port" in str(v):
                # Valeur suivante non nulle
                for k in range(j+1, len(row_list)):
                    val = str(row_list[k]).strip()
                    if val and val != "nan":
                        return val
    return ""
